import React from 'react';

/**
 * Brand Logo Component
 * Handles responsive sizing, variant selection, and theme-aware rendering.
 */
const BrandLogo = ({ 
  variant = 'horizontal', 
  theme = 'light', 
  className = '', 
  isFooter = false 
}) => {
  // Logic to determine which source to pull based on theme/variant
  const getLogoSource = () => {
    if (variant === 'symbol') {
      return theme === 'dark' ? '/images/logo/logo-symbol-white.png' : '/images/logo/logo-symbol-black.png';
    }
    if (variant === 'full') return '/images/logo/logo-full.png';
    return theme === 'dark' ? '/images/logo/logo-horizontal.png' : '/images/logo/logo-horizontal.png';
  };

  return (
    <img 
      src={getLogoSource()} 
      alt="Samuel Paes - Creative Consultant"
      className={`
        object-contain transition-all duration-500 ease-in-out
        ${isFooter ? 'h-8' : 'h-10 md:h-12'}
        ${className}
      `}
      style={{ aspectRatio: 'auto' }}
    />
  );
};

export default function App() {
  return (
    <div className="min-h-screen bg-white">
      {/* Navbar Example */}
      <nav className="flex justify-between items-center p-6 md:px-12 border-b border-gray-100">
        <div className="md:hidden">
          <BrandLogo variant="symbol" />
        </div>
        <div className="hidden md:block">
          <BrandLogo variant="horizontal" />
        </div>
        <div className="text-sm tracking-[0.2em] uppercase font-light">Menu</div>
      </nav>

      {/* Hero Section */}
      <section className="h-[60vh] flex flex-col justify-center items-center text-center">
        <BrandLogo variant="full" className="h-24 md:h-32 mb-8" />
        <p className="text-gray-500 font-light tracking-widest text-sm uppercase">Creative Consultant</p>
      </section>

      {/* Dark Section Example */}
      <section className="bg-black py-24 flex justify-center">
        <BrandLogo variant="symbol" theme="dark" className="h-16 opacity-80 hover:opacity-100" />
      </section>

      {/* Footer */}
      <footer className="py-12 border-t border-gray-100 flex flex-col items-center gap-6">
        <BrandLogo variant="symbol" isFooter={true} />
        <p className="text-[10px] text-gray-400 tracking-tighter">&copy; 2026 Samuel Paes</p>
      </footer>
    </div>
  );
}