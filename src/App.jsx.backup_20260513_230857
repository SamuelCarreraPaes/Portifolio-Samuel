function scrollToId(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
}

function SectionLabel({ children }) {
  return (
    <div className="mb-5 flex items-center gap-3 text-[11px] uppercase tracking-[0.28em] text-stone-500">
      <span className="h-px w-10 bg-stone-300" />
      {children}
    </div>
  );
}

function ImageSlot({ label, tall = false, tone = "neutral", imageSrc, objectPosition = "center center" }) {
  const toneClasses = {
    neutral: "from-stone-200 via-stone-100 to-stone-300",
    dark: "from-stone-950 via-stone-800 to-stone-600",
    red: "from-red-950 via-blue-950 to-stone-100",
    soft: "from-stone-100 via-rose-100 to-amber-100",
    bordeaux: "from-[#2B0A12] via-[#672033] to-[#D8C7BE]",
    pastel: "from-sky-100 via-pink-100 to-orange-100",
  };

  return (
    <div className={`${tall ? "min-h-[520px]" : "min-h-[250px]"} group relative overflow-hidden rounded-[2rem] border border-white/60 bg-gradient-to-br ${toneClasses[tone]} shadow-sm`}>
      {imageSrc ? (
        <img src={imageSrc} alt={label} className="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" style={{ objectPosition }} />
      ) : (
        <>
          <div className="absolute inset-0 opacity-[0.18]" style={{ backgroundImage: "radial-gradient(circle at 1px 1px, rgba(0,0,0,.25) 1px, transparent 0)", backgroundSize: "18px 18px" }} />
          <div className="absolute bottom-5 left-5 right-5 flex items-end justify-between gap-4">
            <span className="max-w-[220px] text-xs leading-relaxed text-stone-700/80">Área reservada para imagem real do projeto.</span>
            <ArrowUpRight className="h-5 w-5 text-stone-700/70" />
          </div>
        </>
      )}

      {/* Layer sutil de contraste para legibilidade das tags caso haja imagem */}
      {imageSrc && <div className="absolute inset-0 bg-stone-900/10 pointer-events-none transition duration-700 group-hover:bg-transparent" />}

      <div className="absolute left-5 top-5 rounded-full bg-white/80 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-stone-800 shadow-sm backdrop-blur-md">
        {label}
      </div>
    </div>
  );
}

function EditorialFrame({ children, accent = "#7A1F1F", className = "" }) {
  return (
    <div className={`relative ${className}`}>
      <div className="absolute -inset-3 rounded-[2.4rem] border border-stone-300/70" />
      <div className="absolute -left-4 top-10 h-24 w-px" style={{ backgroundColor: accent }} />
      <div className="absolute -right-5 bottom-16 h-3 w-3 rounded-full" style={{ backgroundColor: accent }} />
      <div className="relative">{children}</div>
    </div>
  );
}

function CaseCard({ item, index }) {
  const tones = ["red", "soft", "bordeaux", "pastel", "dark", "neutral"];
  const toneIndex = index % tones.length;
  const [open, setOpen] = useState(index === 0);

  return (
    <motion.article
      initial={{ opacity: 0, y: 34 }}
      whileInView={{ opacity: 1, y: 0 }}
      viewport={{ once: true, margin: "-100px" }}
      transition={{ duration: 0.55 }}
      className="mb-10 overflow-hidden rounded-[2.3rem] border border-stone-200 bg-white/70 p-4 shadow-sm backdrop-blur"
    >
      <div className="grid gap-5 lg:grid-cols-[1.08fr_.92fr]">
        <EditorialFrame accent={item.accent}>
          <ImageSlot label={item.title} tall tone={tones[toneIndex]} imageSrc={item.imageSrc} objectPosition={item.objectPosition} />
        </EditorialFrame>

        <div className="flex flex-col justify-between p-2 lg:p-8">
          <div>
            <p className="mb-4 text-[11px] font-semibold uppercase tracking-[0.25em] text-stone-500">{item.eyebrow}</p>
            <h3 className="font-serif text-5xl leading-[0.92] tracking-[-0.06em] text-stone-950 md:text-7xl">{item.title}</h3>
            <p className="mt-5 max-w-xl text-xl leading-snug text-stone-700">{item.descriptor}</p>
            <p className="mt-6 max-w-xl text-sm leading-7 text-stone-600">{item.positioning}</p>
          </div>

          <div className="mt-8 flex flex-wrap gap-2">
            {item.tags.map((tag) => (
              <span key={tag} className="rounded-full border border-stone-300 bg-stone-50 px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-stone-600">
                {tag}
              </span>
            ))}
          </div>

          <button
            onClick={() => setOpen((v) => !v)}
            className="mt-8 flex w-fit items-center gap-2 rounded-full border border-stone-300 px-4 py-2 text-xs uppercase tracking-[0.18em] text-stone-700 transition hover:bg-stone-950 hover:text-white"
          >
            Ver estrutura <ChevronDown className={`h-4 w-4 transition ${open ? "rotate-180" : ""}`} />
          </button>
        </div>
      </div>

      {open && (
        <motion.div initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: "auto" }} className="mt-5">
          <div className="grid gap-4 md:grid-cols-3">
            {item.blocks.map(([title, text]) => (
              <div key={title} className="rounded-[1.6rem] border border-stone-200 bg-stone-50 p-6">
                <p className="mb-3 text-[11px] uppercase tracking-[0.22em] text-stone-500">Capítulo</p>
                <h4 className="font-serif text-2xl leading-tight tracking-[-0.03em] text-stone-950">{title}</h4>
                <p className="mt-4 text-sm leading-6 text-stone-600">{text}</p>
              </div>
            ))}
          </div>

          {item.gallery && item.gallery.length > 0 && (
            <div className={`mt-4 grid grid-cols-1 gap-4 ${[4, 8].includes(item.gallery.length) ? 'sm:grid-cols-2 md:grid-cols-4' : 'sm:grid-cols-3'}`}>
              {item.gallery.map((imgSrc, i) => (
                <div key={i} className="group relative overflow-hidden rounded-[1.6rem] border border-stone-200 shadow-sm aspect-square bg-stone-100">
                  <img 
                    src={imgSrc} 
                    alt={`${item.title} detalhe ${i + 1}`} 
                    className="h-full w-full object-cover transition duration-700 group-hover:scale-105" 
                  />
                  <div className="absolute inset-0 bg-stone-900/10 pointer-events-none transition duration-700 group-hover:bg-transparent" />
                </div>
              ))}
            </div>
          )}
        </motion.div>
      )}
    </motion.article>
  );
}

